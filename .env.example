# Supabase Credentials (Obtain from settings > API in Supabase console)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your-turnstile-site-key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your-turnstile-secret-key
NEXT_PUBLIC_SITE_URL=https://your-production-domain.example

# Location Reference for defaults
NEXT_PUBLIC_DEFAULT_LOCATION_ID=

# Notification Settings
NOTIFICATION_EMAIL_RECIPIENT=your-notification-email@example.com
RESEND_API_KEY=re_your_api_key

