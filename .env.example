# =========================================================================
# PhysioVenture Noida - Static Environment Variables Example
# =========================================================================
# Since this project is deployed as a static HTML site on Cloudflare Pages,
# these variables must be configured in BOTH your local ".env.local" file
# and in your Cloudflare Pages Dashboard under:
# Settings > Environment variables > Build variables (Production & Preview)
# =========================================================================

# 1. Supabase Settings (Obtain from Settings > API in Supabase console)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-sb-key-here"

# 2. Cloudflare Turnstile Settings (Obtain from Cloudflare Turnstile dashboard)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY="your-turnstile-site-key-here"

# 3. Production Website Domain
NEXT_PUBLIC_SITE_URL="https://physioventure.in"

# =========================================================================
# 4. Cloudflare Pages Functions (Edge Workers) runtime variables
# Configure these in the Cloudflare Pages Dashboard (Settings > Environment Variables)
# =========================================================================
# CF_TURNSTILE_SECRET_KEY="your-turnstile-secret-key-here"
# SUPABASE_URL="https://your-project-id.supabase.co"
# SUPABASE_SECRET_KEY="your-supabase-service-role-secret-key-here"
# SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key-here"

